# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# For Homebrew PostgreSQL on macOS (no password): postgresql://your_username@localhost:5432/quant_backtest
DATABASE_URL=postgresql://username@localhost:5432/quant_backtest

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-replace-with-actual-secret

# Backtest Configuration
MAX_CONCURRENT_BACKTESTS=3
CACHE_EXPIRY_DAYS=30

# SocketIO Configuration
SOCKETIO_ASYNC_MODE=threading

# Logging
LOG_LEVEL=INFO
